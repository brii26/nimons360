<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	app:cardBackgroundColor="@color/white"
	app:cardCornerRadius="20dp"
	app:cardElevation="8dp"
	app:strokeWidth="0dp">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="vertical"
		android:paddingStart="16dp"
		android:paddingEnd="16dp"
		android:paddingTop="20dp"
		android:paddingBottom="16dp">

		<!-- Profile row: avatar + name/email -->
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:gravity="center_vertical">

			<com.tit.nimonsapp.ui.common.AvatarView
				android:id="@+id/map_card_avatar"
				android:layout_width="48dp"
				android:layout_height="48dp"
				app:avatarShape="circle"
				app:avatarText="?" />

			<LinearLayout
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:layout_marginStart="12dp"
				android:orientation="vertical">

				<TextView
					android:id="@+id/map_card_name"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="@color/black"
					android:maxLines="1"
					android:ellipsize="end"
					tools:text="Matthew Ivan Widjaja" />

				<TextView
					android:id="@+id/map_card_email"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="2dp"
					android:textSize="13sp"
					android:textColor="@color/section_label"
					android:maxLines="1"
					android:ellipsize="end"
					tools:text="13523142@std.stei.itb.ac.id" />

			</LinearLayout>

		</LinearLayout>

		<!-- Stats row: 3 separate cards -->
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="14dp"
			android:orientation="horizontal">

			<!-- Battery card -->
			<com.google.android.material.card.MaterialCardView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				app:cardBackgroundColor="@color/nimons_bg"
				app:cardCornerRadius="12dp"
				app:cardElevation="0dp"
				app:strokeWidth="0dp">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical"
					android:gravity="center"
					android:padding="12dp">

					<ImageView
						android:layout_width="22dp"
						android:layout_height="22dp"
						android:src="@drawable/ic_battery"
						android:contentDescription="@null"
						app:tint="@color/nimons_green" />

					<LinearLayout
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:orientation="horizontal"
						android:gravity="center_vertical"
						android:layout_marginTop="6dp">

						<TextView
							android:id="@+id/map_card_battery"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:textSize="14sp"
							android:textStyle="bold"
							android:textColor="@color/black"
							tools:text="82%" />

						<ImageView
							android:id="@+id/map_card_charging"
							android:layout_width="14dp"
							android:layout_height="14dp"
							android:layout_marginStart="3dp"
							android:src="@drawable/ic_charging"
							android:contentDescription="@null"
							android:visibility="gone" />

					</LinearLayout>

					<TextView
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginTop="2dp"
						android:text="Battery"
						android:textSize="11sp"
						android:textColor="@color/section_label" />

				</LinearLayout>

			</com.google.android.material.card.MaterialCardView>

			<!-- gap -->
			<View android:layout_width="8dp" android:layout_height="0dp" />

			<!-- Location card -->
			<com.google.android.material.card.MaterialCardView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				app:cardBackgroundColor="@color/nimons_bg"
				app:cardCornerRadius="12dp"
				app:cardElevation="0dp"
				app:strokeWidth="0dp">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical"
					android:gravity="center"
					android:padding="12dp">

					<ImageView
						android:layout_width="22dp"
						android:layout_height="22dp"
						android:src="@drawable/ic_location"
						android:contentDescription="@null"
						app:tint="@color/red" />

					<TextView
						android:id="@+id/map_card_location"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginTop="6dp"
						android:textSize="11sp"
						android:textStyle="bold"
						android:textColor="@color/black"
						android:gravity="center"
						tools:text="-6.891,&#10;107.610" />

					<TextView
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginTop="2dp"
						android:text="Location"
						android:textSize="11sp"
						android:textColor="@color/section_label" />

				</LinearLayout>

			</com.google.android.material.card.MaterialCardView>

			<!-- gap -->
			<View android:layout_width="8dp" android:layout_height="0dp" />

			<!-- Network card -->
			<com.google.android.material.card.MaterialCardView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				app:cardBackgroundColor="@color/nimons_bg"
				app:cardCornerRadius="12dp"
				app:cardElevation="0dp"
				app:strokeWidth="0dp">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical"
					android:gravity="center"
					android:padding="12dp">

					<ImageView
						android:id="@+id/map_card_wifi_icon"
						android:layout_width="22dp"
						android:layout_height="22dp"
						android:src="@drawable/ic_wifi"
						android:contentDescription="@null"
						app:tint="@color/nimons_green" />

					<TextView
						android:id="@+id/map_card_wifi"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginTop="6dp"
						android:textSize="14sp"
						android:textStyle="bold"
						android:textColor="@color/black"
						tools:text="WiFi" />

					<TextView
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginTop="2dp"
						android:text="Network"
						android:textSize="11sp"
						android:textColor="@color/section_label" />

				</LinearLayout>

			</com.google.android.material.card.MaterialCardView>

		</LinearLayout>

	</LinearLayout>

</com.google.android.material.card.MaterialCardView>
