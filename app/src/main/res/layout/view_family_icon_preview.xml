<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.tit.nimonsapp.ui.common.AvatarView
        android:id="@+id/avatar_preview"
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:avatarShape="rounded_square"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <ImageButton
        android:id="@+id/btn_change_icon"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@android:drawable/ic_menu_edit"
        android:contentDescription="Ganti icon"
        android:background="?attr/colorPrimary"
        app:tint="?attr/colorOnPrimary"
        app:layout_constraintEnd_toEndOf="@id/avatar_preview"
        app:layout_constraintBottom_toBottomOf="@id/avatar_preview"/>

</androidx.constraintlayout.widget.ConstraintLayout>
