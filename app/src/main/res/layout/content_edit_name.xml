<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="wrap_content" android:orientation="vertical">

	<TextView android:layout_width="wrap_content"
		android:layout_height="wrap_content" android:text="Edit Name"
		android:textSize="18sp" android:textStyle="bold"
		android:textColor="@color/black" android:layout_marginBottom="20dp" />

	<com.tit.nimonsapp.ui.common.InputFieldView
		android:id="@+id/input_display_name"
		android:layout_width="match_parent"
		android:layout_height="wrap_content" app:labelText="Display Name"
		app:placeholderText="nimons name" app:clearable="true" />

	<TextView android:layout_width="wrap_content"
		android:layout_height="wrap_content" android:layout_marginTop="8dp"
		android:text="This name is visible to your family members."
		android:textSize="12sp"
		android:textColor="?attr/colorOnSurfaceVariant" />

	<LinearLayout android:layout_width="match_parent"
		android:layout_height="wrap_content" android:orientation="horizontal"
		android:layout_marginTop="24dp">

		<com.google.android.material.button.MaterialButton
			android:id="@+id/btn_cancel" style="@style/Button.Destructive"
			android:layout_width="0dp" android:layout_weight="1"
			android:layout_marginEnd="8dp" android:text="Cancel" />

		<com.google.android.material.button.MaterialButton
			android:id="@+id/btn_save" style="@style/Button.Filled"
			android:layout_width="0dp" android:layout_weight="1"
			android:layout_marginStart="8dp" android:text="Save" />

	</LinearLayout>

</LinearLayout>
