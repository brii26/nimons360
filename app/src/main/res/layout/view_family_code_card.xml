<?xml version="1.0" encoding="utf-8"?>
<!--
    <include layout="@layout/view_family_code_card" android:id="@+id/family_code_card"/>
    set code: binding.familyCodeCard.tvFamilyCode.text = family.code
    hide kalo bukan owner: binding.familyCodeCard.root.visibility = View.GONE
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_family_code"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_code_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Family Code"
        android:textSize="12sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tv_family_code"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="20sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:textColor="?attr/colorOnSurface"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_copy_code"
        app:layout_constraintTop_toBottomOf="@id/tv_code_label"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <ImageButton
        android:id="@+id/btn_copy_code"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_copy"
        android:contentDescription="Copy code"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="?attr/colorPrimary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
