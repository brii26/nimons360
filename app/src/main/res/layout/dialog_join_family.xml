<?xml version="1.0" encoding="utf-8"?>
<!--
    inflate ke MaterialAlertDialogBuilder: val view = layoutInflater.inflate(R.layout.dialog_join_family, null)
    ambil kode nya: view.findViewById<InputFieldView>(R.id.input_join_code).text
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gabung Family"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Masukin kode yang dikasih sama owner family."
        android:textSize="14sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginBottom="16dp"/>

    <com.tit.nimonsapp.ui.common.InputFieldView
        android:id="@+id/input_join_code"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>
