<?xml version="1.0" encoding="utf-8"?>
<ScrollView
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	style="@style/ScrollViewDefault"
>

	<LinearLayout 
		style="@style/Login.Container" >

		<LinearLayout
			style="@style/Login.Header" >
			<include
				android:id="@+id/app_logo"
				layout="@layout/view_icon_container"
				android:layout_width="120dp"
				android:layout_height="120dp" />

			<TextView android:id="@+id/login_title"
				style="@style/Login.Title"
				android:text="@string/login_title" />

			<TextView android:id="@+id/login_subtitle"
				style="@style/Login.Subtitle"
				android:text="@string/login_subtitle" />
		</LinearLayout>

		<EditText android:id="@+id/email_input"
			style="@style/Login.Input"
			android:layout_marginTop="24dp"
			android:hint="@string/login_email_placeholder"
			android:inputType="textEmailAddress" />

		<EditText android:id="@+id/password_input"
			style="@style/Login.Input"
			android:layout_marginTop="12dp"
			android:hint="@string/login_password_placeholder"
			android:inputType="textPassword" />

		<TextView android:id="@+id/error_text"
			style="@style/Login.ErrorText"
			tools:text="Invalid email or password"
			tools:visibility="visible" />

		<ProgressBar android:id="@+id/loading_indicator"
			style="@style/Login.LoadingIndicator"
			tools:visibility="visible" />

		<Button
			android:id="@+id/login_button"
			style="@style/Button.Login"
			android:text="@string/login_button"
		/>

	</LinearLayout>
</ScrollView>
