<?xml version="1.0" encoding="utf-8"?>
<ScrollView
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	style="@style/ScrollViewDefault"
>

	<LinearLayout 
		style="@style/Login.Container" >

		<LinearLayout
			style="@style/Login.Header" >
			<ImageView
				android:id="@+id/app_logo"
				android:src="@drawable/ic_app_border"
				android:layout_width="128dp"
				android:layout_height="128dp"/>

			<TextView android:id="@+id/login_title"
				style="@style/Login.Title"
				android:text="@string/login_title" />

			<TextView android:id="@+id/login_subtitle"
				style="@style/Login.Subtitle"
				android:text="@string/login_subtitle" />
		</LinearLayout>

		<com.tit.nimonsapp.ui.common.InputFieldView
			android:id="@+id/email_input"
			style="@style/Login.Input"
			android:layout_marginTop="24dp"
			app:leftIcon="@drawable/ic_mail"
			app:placeholderText="@string/login_email_placeholder" />

		<com.tit.nimonsapp.ui.common.InputFieldView
			android:id="@+id/password_input"
			style="@style/Login.Input"
			android:layout_marginTop="12dp"
			app:leftIcon="@drawable/ic_lock"
			app:placeholderText="@string/login_password_placeholder"
			app:rightActionText="Show" />

		<TextView android:id="@+id/error_text"
			style="@style/Login.ErrorText"
			tools:text="Invalid email or password"
			tools:visibility="visible" />

		<ProgressBar android:id="@+id/loading_indicator"
			style="@style/Login.LoadingIndicator"
			tools:visibility="visible" />

		<com.tit.nimonsapp.ui.common.ButtonPrimaryView
			android:id="@+id/login_button"
			style="@style/Button.Primary.Login"
			android:text="@string/login_button" />

	</LinearLayout>
</ScrollView>
