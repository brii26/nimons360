<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Container untuk marker utama agar posisinya pas di tengah -->
    <FrameLayout
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <View
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_current_user_marker_with_arrow" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_person"
            app:tint="@android:color/white" />

        <ImageView
            android:id="@+id/iv_arrow"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="48dp"
            android:src="@drawable/ic_navigation_arrow" />

        <!-- AvatarView ini hidden, tapi ID-nya dipake buat setLetter di Kotlin -->
        <com.tit.nimonsapp.ui.common.AvatarView
            android:id="@+id/marker_avatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:visibility="visible" />

    </FrameLayout>
</FrameLayout>
