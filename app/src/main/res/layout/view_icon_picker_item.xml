<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="wrap_content"
	android:layout_height="wrap_content" android:layout_margin="8dp"
	android:background="@drawable/bg_icon_picker_item"
	android:clickable="true" android:focusable="true"
	android:foreground="?attr/selectableItemBackgroundBorderless">

	<ImageView android:id="@+id/iv_icon_item"
		android:layout_width="48dp" android:layout_height="48dp"
		android:layout_gravity="center" android:padding="8dp"
		android:scaleType="centerInside" android:contentDescription="@null" />

</FrameLayout>