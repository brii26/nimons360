<?xml version="1.0" encoding="utf-8"?>
<ScrollView
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	tools:context="com.tit.nimonsapp.ui.profile.ProfileFragment">

	<LinearLayout android:layout_width="match_parent"
		android:layout_height="wrap_content" android:orientation="vertical"
		android:padding="24dp">

		<TextView android:id="@+id/profile_title"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" android:text="Profile"
			android:textSize="28sp" android:textStyle="bold" />

		<ProgressBar android:id="@+id/loading_indicator"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content" android:layout_marginTop="16dp"
			android:visibility="gone" tools:visibility="visible" />

		<TextView android:id="@+id/error_text"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="12dp"
			android:textColor="@android:color/holo_red_dark"
			android:visibility="gone" tools:text="Failed to load profile"
			tools:visibility="visible" />

		<TextView android:id="@+id/nim_label"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="20dp"
			android:text="NIM" />

		<TextView android:id="@+id/nim_value"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" tools:text="13523142" />

		<TextView android:id="@+id/email_label"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="16dp"
			android:text="Email" />

		<TextView android:id="@+id/email_value"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			tools:text="13523142@std.stei.itb.ac.id" />

		<TextView android:id="@+id/full_name_label"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="16dp"
			android:text="Full Name" />

		<EditText android:id="@+id/full_name_input"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" android:hint="Full name"
			android:inputType="textPersonName" tools:text="Matthew Ivan Widjaja" />

		<Button android:id="@+id/update_profile_button"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="20dp"
			android:text="Update Profile" />

		<Button android:id="@+id/go_home_button"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="12dp"
			android:text="Go to Home" />

		<Button android:id="@+id/logout_button"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="12dp"
			android:text="Logout" />

	</LinearLayout>
</ScrollView>
