<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="wrap_content" android:orientation="vertical"
	android:background="@drawable/border"
	android:backgroundTint="@android:color/white" android:padding="16dp">

	<!-- Header: Avatar + Name + Email -->
	<LinearLayout android:layout_width="match_parent"
		android:layout_height="wrap_content" android:orientation="horizontal"
		android:gravity="center_vertical">

		<com.tit.nimonsapp.ui.common.AvatarView
			android:id="@+id/avatar" android:layout_width="50dp"
			android:layout_height="50dp" app:avatarShape="circle"
			app:avatarText="L" app:avatarBgColor="?attr/colorPrimary" />

		<LinearLayout android:layout_width="match_parent"
			android:layout_height="wrap_content" android:orientation="vertical"
			android:layout_marginStart="12dp">

			<TextView android:id="@+id/tvUserName"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content" android:textSize="18sp"
				android:textStyle="bold" android:textColor="@android:color/black"
				tools:text="Labpro ITB" />

			<TextView android:id="@+id/tvUserEmail"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content" android:textSize="14sp"
				android:textColor="@color/section_label"
				android:layout_marginTop="2dp"
				tools:text="labpro@std.stei.itb.ac.id" />

		</LinearLayout>

	</LinearLayout>

	<!-- Divider -->
	<View android:layout_width="match_parent"
		android:layout_height="1dp"
		android:background="@color/chip_unselected_stroke"
		android:layout_marginTop="16dp" android:layout_marginBottom="16dp" />

	<!-- Footer: 3 Columns (Battery, Location, WiFi) -->
	<LinearLayout android:layout_width="match_parent"
		android:layout_height="wrap_content" android:orientation="horizontal">

		<!-- Battery Column -->
		<LinearLayout android:layout_width="0dp"
			android:layout_height="wrap_content" android:layout_weight="1"
			android:orientation="vertical" android:gravity="center">

			<ImageView android:id="@+id/ivBatteryIcon"
				android:layout_width="24dp" android:layout_height="24dp"
				android:src="@drawable/ic_battery" app:tint="@color/nimons_green"
				android:contentDescription="@null" />

			<LinearLayout android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:orientation="horizontal" android:gravity="center_vertical"
				android:layout_marginTop="4dp">

				<TextView android:id="@+id/tvBatteryValue"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content" android:textSize="14sp"
					android:textStyle="bold" android:textColor="@android:color/black"
					tools:text="82%" />

				<ImageView android:id="@+id/ivCharging"
					android:layout_width="16dp" android:layout_height="16dp"
					android:layout_marginStart="4dp"
					android:src="@drawable/ic_charging" android:visibility="gone"
					android:contentDescription="@null" />
			</LinearLayout>

			<TextView android:layout_width="wrap_content"
				android:layout_height="wrap_content" android:textSize="12sp"
				android:textColor="@color/section_label" android:text="Battery" />

		</LinearLayout>

		<!-- Location Column -->
		<LinearLayout android:layout_width="0dp"
			android:layout_height="wrap_content" android:layout_weight="1"
			android:orientation="vertical" android:gravity="center">

			<ImageView android:id="@+id/ivLocationIcon"
				android:layout_width="24dp" android:layout_height="24dp"
				android:src="@drawable/ic_location" app:tint="@color/red"
				android:contentDescription="@null" />

			<TextView android:id="@+id/tvLocationValue"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content" android:textSize="12sp"
				android:textStyle="bold" android:textColor="@android:color/black"
				android:layout_marginTop="4dp" tools:text="-6.891, 107.610" />

			<TextView android:layout_width="wrap_content"
				android:layout_height="wrap_content" android:textSize="12sp"
				android:textColor="@color/section_label" android:text="Location" />

		</LinearLayout>

		<!-- WiFi Column -->
		<LinearLayout android:layout_width="0dp"
			android:layout_height="wrap_content" android:layout_weight="1"
			android:orientation="vertical" android:gravity="center">

			<ImageView android:id="@+id/ivWifiIcon"
				android:layout_width="24dp" android:layout_height="24dp"
				android:src="@drawable/ic_wifi" app:tint="@color/nimons_green"
				android:contentDescription="@null" />

			<TextView android:id="@+id/tvWifiValue"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content" android:textSize="14sp"
				android:textStyle="bold" android:textColor="@android:color/black"
				android:layout_marginTop="4dp" tools:text="WiFi" />

			<TextView android:layout_width="wrap_content"
				android:layout_height="wrap_content" android:textSize="12sp"
				android:textColor="@color/section_label" android:text="Network" />

		</LinearLayout>

	</LinearLayout>

</LinearLayout>
