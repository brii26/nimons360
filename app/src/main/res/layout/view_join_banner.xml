<?xml version="1.0" encoding="utf-8"?>
<!--
    <include layout="@layout/view_join_banner" android:id="@+id/join_banner"/>
    handle tap nya: binding.joinBanner.root.setOnClickListener { showJoinFamilyDialog() }
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_join_banner"
    android:paddingVertical="12dp"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <TextView
        android:id="@+id/tv_join_banner_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Udah punya kode?"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/iv_join_arrow"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tv_join_banner_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Gabung ke family yang udah ada"
        android:textSize="12sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/iv_join_arrow"
        app:layout_constraintTop_toBottomOf="@id/tv_join_banner_title"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <ImageView
        android:id="@+id/iv_join_arrow"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@android:drawable/ic_media_play"
        android:contentDescription="@null"
        app:tint="?attr/colorPrimary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
