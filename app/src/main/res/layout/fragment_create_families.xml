<?xml version="1.0" encoding="utf-8"?>
<ScrollView
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	tools:context="com.tit.nimonsapp.ui.createfamily.CreateFamilyFragment">

	<LinearLayout android:layout_width="match_parent"
		android:layout_height="wrap_content" android:orientation="vertical"
		android:padding="24dp">

		<TextView android:id="@+id/create_family_title"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" android:text="Create Family"
			android:textSize="28sp" android:textStyle="bold" />

		<EditText android:id="@+id/family_name_input"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="24dp"
			android:hint="Family name" android:inputType="textCapWords"
			tools:text="The Lion Is Theo" />

		<EditText android:id="@+id/family_icon_url_input"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="12dp"
			android:hint="Icon URL" android:inputType="textUri"
			tools:text="https://mad.labpro.hmif.dev/assets/family_icon_1.png" />

		<TextView android:id="@+id/error_text"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="12dp"
			android:textColor="@android:color/holo_red_dark"
			android:visibility="gone" tools:text="Failed to create family"
			tools:visibility="visible" />

		<ProgressBar android:id="@+id/loading_indicator"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content" android:layout_marginTop="16dp"
			android:visibility="gone" tools:visibility="visible" />

		<Button android:id="@+id/create_family_button"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="16dp"
			android:text="Create Family" />

		<Button android:id="@+id/go_home_button"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="12dp"
			android:text="Go to Home" />

		<Button android:id="@+id/go_families_button"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="12dp"
			android:text="Go to Families" />

	</LinearLayout>
</ScrollView>
