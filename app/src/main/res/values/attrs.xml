<resources>

    <declare-styleable name="InputField">
        <attr name="leftIcon" format="reference" />
        <attr name="placeholderText" format="string" />
        <attr name="rightActionText" format="string" />
    </declare-styleable>


    <declare-styleable name="AvatarView">
        <attr name="avatarShape" format="enum">
            <enum name="circle" value="0" />
            <enum name="rounded_square" value="1" />
        </attr>
        <attr name="avatarText" format="string" />
        <attr name="avatarBgColor" format="color|reference" />
    </declare-styleable>

    <declare-styleable name="ListRowView">
        <attr name="rowPrimaryText" format="string" />
        <attr name="rowSecondaryText" format="string" />
        <attr name="rowRightType" format="enum">
            <enum name="none" value="0" />
            <enum name="pin" value="1" />
            <enum name="badge" value="2" />
        </attr>
        <attr name="rowBadgeText" format="string" />
    </declare-styleable>

</resources>
