<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:app="http://schemas.android.com/apk/res-auto">

	<!-- General -->
	<style name="Button" parent="Widget.MaterialComponents.Button" />

	<style name="ScrollViewDefault">
		<item name="android:layout_width">match_parent</item>
		<item name="android:layout_height">match_parent</item>
		<item name="android:fillViewport">true</item>
	</style>

	<style name="Button.Primary">
		<item name="android:layout_width">wrap_content</item>
		<item name="android:layout_height">wrap_content</item>
		<item name="cornerRadius">12dp</item>
		<item name="buttonColor">@color/primary</item>
		<item name="buttonTextColor">@color/white</item>
	</style>

	<!-- Input Field -->
	<style name="StyleLeftIcon">
		<item name="android:layout_width">24dp</item>
		<item name="android:layout_height">24dp</item>
	</style>

	<style name="StyleContent">
		<item name="android:layout_width">0dp</item>
		<item name="android:layout_height">wrap_content</item>
		<item name="android:layout_marginStart">12dp</item>
	</style>

	<style name="StyleRightAction">
		<item name="android:layout_width">wrap_content</item>
		<item name="android:layout_height">wrap_content</item>
	</style>

	<!-- Login -->
	<style name="Login" />

	<style name="Login.Container">
		<item name="android:layout_width">match_parent</item>
		<item name="android:layout_height">wrap_content</item>
		<item name="android:orientation">vertical</item>
		<item name="android:padding">24dp</item>
		<item name="android:gravity">center_vertical</item>
		<item name="android:layout_marginBottom">10dp</item>
	</style>

	<style name="Login.Header">
		<item name="android:layout_width">match_parent</item>
		<item name="android:layout_height">wrap_content</item>
		<item name="android:gravity">center_horizontal</item>
		<item name="android:orientation">vertical</item>
		<item name="android:layout_marginBottom">8dp</item>
	</style>

	<style name="Login.Title">
		<item name="android:fontFamily">sans-serif-black</item>
		<item name="android:layout_width">wrap_content</item>
		<item name="android:layout_height">wrap_content</item>
		<item name="android:layout_marginTop">8dp</item>
		<item name="android:textSize">28sp</item>
	</style>

	<style name="Login.Subtitle">
		<item name="android:layout_width">wrap_content</item>
		<item name="android:layout_height">wrap_content</item>
		<item name="android:textSize">16sp</item>
	</style>

	<style name="Login.Input">
		<item name="android:layout_width">match_parent</item>
		<item name="android:layout_height">wrap_content</item>
		<item name="android:background">@drawable/border</item>
		<item name="android:padding">8dp</item>
		<item name="cornerRadius">5dp</item>
	</style>

	<style name="Login.ErrorText">
		<item name="android:layout_width">match_parent</item>
		<item name="android:layout_height">wrap_content</item>
		<item name="android:layout_marginTop">12dp</item>
		<item name="android:textColor">@color/error</item>
		<item name="android:visibility">gone</item>
	</style>

	<style name="Login.LoadingIndicator">
		<item name="android:layout_width">wrap_content</item>
		<item name="android:layout_height">wrap_content</item>
		<item name="android:layout_marginTop">16dp</item>
		<item name="android:visibility">gone</item>
	</style>

	<style name="Button.Primary.Login">
		<item name="android:layout_width">match_parent</item>
		<item name="android:layout_height">wrap_content</item>
		<item name="android:layout_marginTop">16dp</item>
		<item name="android:paddingVertical">10dp</item>
	</style>

</resources>
