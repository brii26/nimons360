<?xml version="1.0" encoding="utf-8"?>
<navigation
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/navigation_graphs"
	app:startDestination="@id/startupFragment">
	<!-- ini buat testing GPS doang -->
	<!--app:startDestination="@id/locationTestFragment">-->

	<!-- startup route -->
	<fragment android:id="@+id/startupFragment"
		android:name="com.tit.nimonsapp.ui.startup.StartupFragment"
		android:label="startup">

		<action
			android:id="@+id/action_startupFragment_to_loginFragment"
			app:destination="@id/loginFragment" app:popUpTo="@id/navigation_graphs"
			app:popUpToInclusive="true" />

		<action
			android:id="@+id/action_startupFragment_to_homeFragment"
			app:destination="@id/homeFragment" app:popUpTo="@id/navigation_graphs"
			app:popUpToInclusive="true" />
	</fragment>

	<!-- login route -->
	<fragment android:id="@+id/loginFragment"
		android:name="com.tit.nimonsapp.ui.login.LoginFragment"
		android:label="login" tools:layout="@layout/fragment_login">

		<action android:id="@+id/action_loginFragment_to_homeFragment"
			app:destination="@id/homeFragment" app:popUpTo="@id/loginFragment"
			app:popUpToInclusive="true" />
	</fragment>

	<!-- home route -->
	<fragment android:id="@+id/homeFragment"
		android:name="com.tit.nimonsapp.ui.home.HomeFragment"
		android:label="home">

		<action
			android:id="@+id/action_homeFragment_to_profileFragment"
			app:destination="@id/profileFragment" />

		<action
			android:id="@+id/action_homeFragment_to_createFamilyFragment"
			app:destination="@id/createFamilyFragment" />
	</fragment>

	<!-- families route -->
	<fragment android:id="@+id/familiesFragment"
		android:name="com.tit.nimonsapp.ui.families.FamiliesFragment"
		android:label="families" tools:layout="@layout/fragment_families">

		<action
			android:id="@+id/action_familiesFragment_to_familyDetailFragment"
			app:destination="@id/familyDetailFragment" />

		<action
			android:id="@+id/action_familiesFragment_to_createFamilyFragment"
			app:destination="@id/createFamilyFragment" />
	</fragment>

	<!-- map route -->
	<fragment android:id="@+id/mapFragment"
		android:name="com.tit.nimonsapp.ui.map.MapFragment"
		android:label="map" />

	<!-- family detail route -->
	<fragment android:id="@+id/familyDetailFragment"
		android:name="com.tit.nimonsapp.ui.familydetail.FamilyDetailFragment"
		android:label="family_detail">

		<argument android:name="familyId" app:argType="integer"
			android:defaultValue="-1" />

		<action
			android:id="@+id/action_familyDetailFragment_to_familiesFragment"
			app:destination="@id/familiesFragment" />
	</fragment>

	<!-- profile route -->
	<fragment android:id="@+id/profileFragment"
		android:name="com.tit.nimonsapp.ui.profile.ProfileFragment"
		android:label="profile" tools:layout="@layout/fragment_profile">

		<action
			android:id="@+id/action_profileFragment_to_homeFragment"
			app:destination="@id/homeFragment" />

		<action
			android:id="@+id/action_profileFragment_to_loginFragment"
			app:destination="@id/loginFragment" app:popUpTo="@id/navigation_graphs"
			app:popUpToInclusive="true" />
	</fragment>

	<!-- create family route -->
	<fragment android:id="@+id/createFamilyFragment"
		android:name="com.tit.nimonsapp.ui.createfamily.CreateFamilyFragment"
		android:label="create_family"
		tools:layout="@layout/fragment_create_families">

		<action
			android:id="@+id/action_createFamilyFragment_to_homeFragment"
			app:destination="@id/homeFragment" />

		<action
			android:id="@+id/action_createFamilyFragment_to_familiesFragment"
			app:destination="@id/familiesFragment" />
	</fragment>

	<!-- location test route -->
	<fragment android:id="@+id/locationTestFragment"
		android:name="com.tit.nimonsapp.ui.LocationTestFragment"
		android:label="location_test"
		tools:layout="@layout/fragment_location_test" />

</navigation>
